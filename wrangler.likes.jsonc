{
  // 仅供喜欢系统的 D1 migration 与本地 Pages Functions 开发使用。
  // Pages 生产配置的真相源是仓库根 wrangler.jsonc；此文件保持最小化，供显式 --config 调用。
  "name": "novelai-tag-likes-local",
  "compatibility_date": "2026-07-11",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "COMMUNITY_DB",
      "database_name": "novelai-tag-community",
      "migrations_dir": "migrations"
    }
  ]
}
