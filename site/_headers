# JS/CSS freshness is controlled only by no-store below.
# Version query strings (?v=YYYYMMDD-cacheN) were intentionally removed; do not add them back.
/assets/app.js
  Cache-Control: no-store

/assets/app/*.js
  Cache-Control: no-store

/assets/styles.css
  Cache-Control: no-store

/review.html
  Cache-Control: no-store
