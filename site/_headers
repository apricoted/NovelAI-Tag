# Keep the handwritten ES module graph fresh. Without a build step that hashes
# child module filenames, stale browser caches can mix new and old modules.
/assets/app.js
  Cache-Control: no-store

/assets/app/*.js
  Cache-Control: no-store

/assets/styles.css
  Cache-Control: no-store

/review.html
  Cache-Control: no-store
